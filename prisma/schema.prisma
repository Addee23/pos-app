generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  PERSONAL
  ADMIN
}

enum ProductType {
  SIMPLE
  VARIABLE
}

enum StockMovementType {
  SALE
  ADJUSTMENT
  RESTOCK
  RETURN
  SYNC
}

enum PickupStatus {
  READY
  PICKED_UP
  CANCELLED
}

model Store {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logoUrl         String?
  wooUrl          String?
  wooConsumerKey  String?  @db.Text
  wooConsumerSecret String? @db.Text
  wooWebhookSecret  String? @db.Text
  smtpHost       String?
  smtpPort       Int?
  smtpSecure     Boolean  @default(false)
  smtpUser       String?  @db.Text
  smtpPass       String?  @db.Text
  smtpFrom       String?
  address         String?
  receiptFooter   String?
  returnText      String?
  thankYouMessage String?
  socialLinks     String?
  receiptWidthMm  Int      @default(80)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users          User[]
  products       Product[]
  auditLogs      AuditLog[]
  sales          Sale[]
  stockMovements StockMovement[]
  pickups        Pickup[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(PERSONAL)
  storeId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store          Store?          @relation(fields: [storeId], references: [id], onDelete: SetNull)
  auditLogs      AuditLog[]
  sales          Sale[]
  stockMovements StockMovement[]
  pickedUpPickups Pickup[]        @relation("PickupPickedUpBy")
  cancelledPickups Pickup[]        @relation("PickupCancelledBy")
}

model Product {
  id            String      @id @default(cuid())
  storeId       String
  wooProductId  Int
  name          String
  slug          String
  permalink     String?
  productType   ProductType @default(SIMPLE)
  price         Decimal     @db.Decimal(10, 2)
  ean           String?
  imageUrl      String?     @db.Text
  metaDescription String?   @db.Text
  shortDescription String?  @db.Text
  category      String?
  brand         String?
  country       String?
  stockQuantity Int         @default(0)
  stockLocation String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  store          Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants       ProductVariant[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]
  pickupItems    PickupItem[]

  @@unique([storeId, wooProductId])
  @@index([storeId, name])
  @@index([storeId, ean])
  @@index([storeId, category])
  @@index([storeId, brand])
  @@index([storeId, country])
  @@index([slug])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  wooVariantId  Int
  name          String
  price         Decimal  @db.Decimal(10, 2)
  ean           String?
  imageUrl      String?  @db.Text
  metaDescription String? @db.Text
  shortDescription String? @db.Text
  stockQuantity Int      @default(0)
  stockLocation String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  saleItems      SaleItem[]
  stockMovements StockMovement[]
  pickupItems    PickupItem[]

  @@unique([productId, wooVariantId])
  @@index([ean])
}

model Sale {
  id        String   @id @default(cuid())
  storeId   String
  userId    String?
  total     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  store Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  items SaleItem[]

  @@index([storeId, createdAt])
  @@index([userId, createdAt])
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  productId   String?
  variantId   String?
  productName String
  variantName String?
  ean         String?
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  sale           Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product        Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]

  @@index([saleId])
  @@index([productId])
  @@index([variantId])
}

model StockMovement {
  id             String            @id @default(cuid())
  storeId        String
  productId      String?
  variantId      String?
  saleItemId     String?
  userId         String?
  type           StockMovementType
  quantityChange Int
  quantityBefore Int?
  quantityAfter  Int?
  reason         String?
  createdAt      DateTime          @default(now())

  store    Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product  Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  saleItem SaleItem?       @relation(fields: [saleItemId], references: [id], onDelete: SetNull)
  user     User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
  @@index([variantId, createdAt])
  @@index([saleItemId])
}

model Pickup {
  id           String       @id @default(cuid())
  storeId      String
  customerName String
  customerEmail String?
  pickupCode   String
  status       PickupStatus @default(READY)
  notes        String?
  readyEmailSentAt DateTime?
  pickedUpAt   DateTime?
  pickedUpById String?
  cancelledAt  DateTime?
  cancelledById String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  store      Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  pickedUpBy User? @relation("PickupPickedUpBy", fields: [pickedUpById], references: [id], onDelete: SetNull)
  cancelledBy User? @relation("PickupCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  items      PickupItem[]

  @@unique([storeId, pickupCode])
  @@index([storeId, status])
  @@index([customerName])
  @@index([customerEmail])
  @@index([cancelledById])
}

model PickupItem {
  id              String   @id @default(cuid())
  pickupId        String
  productId       String?
  variantId       String?
  productName     String
  variantName     String?
  productSlug     String?
  productImageUrl String?  @db.Text
  quantity        Int      @default(1)
  createdAt       DateTime @default(now())

  pickup  Pickup          @relation(fields: [pickupId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([pickupId])
  @@index([productId])
  @@index([variantId])
  @@index([productSlug])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  storeId    String?
  entityType String
  entityId   String
  field      String
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([entityType, entityId])
}
