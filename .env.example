# Kopiera till .env och fyll i värdena
DATABASE_URL="mysql://pos:pos_password@localhost:3306/pos_app"

# Generera med PowerShell:
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
AUTH_SECRET="byt-ut-till-en-lang-hemlig-nyckel"

NEXTAUTH_URL="http://localhost:3000"

# SMTP för upphämtningsmail (Gmail-exempel)
# Skapa app-lösenord: Google-konto -> Säkerhet -> App-lösenord
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="din-gmail@gmail.com"
SMTP_PASS="ditt-app-losenord"
SMTP_FROM="POS Demo <din-gmail@gmail.com>"

# Standard testmottagare i admin (kan ändras i UI)
SMTP_TEST_RECIPIENT="dentalflow13@gmail.com"
TEST_CUSTOMER_EMAIL="din-testmail@gmail.com"

# Valfritt: kartbild från Google i upphämtningsmail (utan nyckel = förhandsbild + länk till Google Maps)
# GOOGLE_MAPS_API_KEY="din-google-maps-api-nyckel"

# Valfritt: butiksslug för import/simulering (standard demo-butik)
# IMPORT_STORE_SLUG="demo-butik"

# WooCommerce – fyll i och kör: npm run setup:woo (sparas i databasen, inte i kod)
# WOO_URL="https://er-butik.se"
# WOO_CONSUMER_KEY="ck_..."
# WOO_CONSUMER_SECRET="cs_..."
# WOO_WEBHOOK_SECRET="samma som i Woo webhook Order created"

# Woo webhooks: test = lokal simulering, production = riktig butik
WOOCOMMERCE_WEBHOOK_MODE="test"
# I test + development: simulate kan köras utan signatur om dev-server anropas med SKIP
WOOCOMMERCE_WEBHOOK_SKIP_SIGNATURE="true"
# Secret för npm run test:woo-webhook (samma som i Inställningar → Webhook Secret)
WOO_WEBHOOK_TEST_SECRET="test-webhook-secret"
# Production: endast dessa fraktmetoder skapar upphämtning (kommaseparerat)
# WOO_PICKUP_SHIPPING_METHOD_IDS="local_pickup,pickup_location"
