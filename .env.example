# Kopiera till .env och fyll i värdena
DATABASE_URL="mysql://pos:pos_password@localhost:3306/pos_app"

# Generera med: openssl rand -base64 32
# Eller i PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
AUTH_SECRET="byt-ut-till-en-lang-hemlig-nyckel"

# Lokal utveckling
NEXTAUTH_URL="http://localhost:3000"
